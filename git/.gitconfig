[user]
    name = Stefan Chipilov
[core]
    editor=vim
[color]
    ui = auto
[alias]
    st = !cd -- ${GIT_PREFIX:-.} && git status && "echo -e \"Hidden files:\\n\\033[35m\"" && git ls-files -v $(git rev-parse --show-toplevel) | grep '^[[:lower:]]' | sed 's/h /    !!! /' && "echo -e \"\\033[0m\""
    d = diff --color-words -w
    dc = diff --color-words -w --cached
    aa = !git add --all
    au = !git add --update
    co = checkout
    b = branch
    fo = remote update -p
    so = remote show origin
    lg = log --graph --pretty=format:'%C(yellow)%h%Creset %s %C(green)%an %cD%Creset %C(red)%d%Creset' --abbrev-commit
    up = !git remote update -p && git merge --ff-only @{u}
    hide = update-index --skip-worktree
    unhide = update-index --no-skip-worktree
    unhide-all = !git ls-files -v | grep '^S' | cut -d ' ' -f 2 | xargs git unhide
    hidden = !cd -- ${GIT_PREFIX:-.} && "echo \"Hidden files:\\n\\033[35m\"" && git ls-files -v | grep '^S' | sed 's/S /    !!! /' && "echo \"\\033[0m\""
    revert-last-change = "!f() { \
        file=\"$1\"; \
        index=\"${2:-1}\"; \
        if [ -z \"$file\" ]; then echo \"usage: git revert-last-file-change <file> [index]\" >&2; return 1; fi; \
        case \"$index\" in ''|*[!0-9]*) echo \"index must be a positive integer\" >&2; return 1 ;; esac; \
        [ \"$index\" -ge 1 ] || { echo \"index must be >= 1\" >&2; return 1; }; \
        commit=$(git log --skip \"$((index - 1))\" -1 --format=%H -- \"$file\") || return 1; \
        if [ -z \"$commit\" ]; then echo \"no commit at index $index for $file\" >&2; return 1; fi; \
        git restore --source \"${commit}~1\" -- \"$file\"; \
    }; f"
[merge]
    conflictstyle = diff3
[push]
    default = simple
    autoSetupRemote = true
[diff]
    renameLimit = 8000
[status]
    relativePaths = true
[filter "lfs"]
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
